.env.production
*.key

# Compiled assets - These are generated on build
/public/hot
/public/storage
/public/build
/storage/*.key

# Caches and Logs - HostGator generates these at runtime
/storage/framework/cache/data/*
/storage/framework/sessions/*
/storage/framework/views/*
/storage/logs/*.log
/bootstrap/cache/*.php

# Testing & IDEs
.phpunit.result.cache
.idea/
.vscode/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# OS generated files
.DS_Store
Thumbs.db
